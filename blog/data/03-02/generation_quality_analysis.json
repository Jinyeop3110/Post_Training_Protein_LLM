  "key_findings": [
    {
      "id": 0,
      "title": "Baseline (no SFT) has near-zero protein task performance",
      "detail": "Qwen3-8B without fine-tuning achieves only 0.033 avg word overlap (0/20 high-similarity samples). Outputs are fluent but task-irrelevant. All SFT approaches improve dramatically: text-only 13.4x, MLP 10.5x, Perceiver 9.0x higher word overlap."
    },
    {
      "id": 1,
      "title": "Text-only achieves highest generation quality despite comparable eval_loss",
      "detail": "Text-only avg word overlap 0.443 vs MLP 0.346 vs Perceiver 0.296 at final steps. Text-only gets 5/25 high-similarity samples vs MLP 4/25 vs Perceiver 3/25."
    },
    {
      "id": 2,
      "title": "Perceiver suffers severe mode collapse on catalytic tasks",
      "detail": "3 out of 5 catalytic samples produce identical output (ATP + L-tyrosyl-[protein]...) regardless of input protein. Also collapses on domain prediction (YjeF N-terminal for 3/5)."
    },
    {
      "id": 3,
      "title": "MLP has stock sequence collapse for protein design",
      "detail": "All 5 design samples and some function samples start with 'MSSKQVYR...' \u2014 a memorized signal peptide prefix, not conditioned on the instruction or functional requirements."
    },
    {
      "id": 4,
      "title": "Perceiver produces degenerate single-character repetition",
      "detail": "6/25 samples at final step are degenerate (SSSSS..., EEEEE..., DDDDD...). Worst cases: pure 'S' repeated 300+ times for design/function/general tasks."
    },
    {
      "id": 5,
      "title": "Text-only achieves exact catalytic reaction matches",
      "detail": "Text-only correctly predicts 'phosphate + xanthosine = alpha-D-ribose 1-phosphate + xanthine' (sample 2) and 'ATP + H2O = ADP + H(+) + phosphate' (sample 5) \u2014 neither ESM3 variant does."
    },
    {
      "id": 6,
      "title": "Text-only generates more diverse and longer protein sequences for design tasks",
      "detail": "Text-only design sequences average ~300 chars with varied content, while MLP generates ~80-128 char stock sequences and Perceiver often degenerates to single-char repetition."
    },
    {
      "id": 7,
      "title": "All approaches struggle with design tasks (0/5 high similarity for all)",
      "detail": "Design tasks (open-ended protein generation) have 0/5 high-similarity samples across all approaches. This is expected since exact sequence match is unlikely for generative tasks."
    },
    {
      "id": 8,
      "title": "Quality does not consistently improve with more training steps",
      "detail": "Text-only peaks around step_500-750 (avg_sim 0.497-0.434) then fluctuates. Perceiver and MLP show minimal improvement between step_250 and step_1677."
    }
  ]
}